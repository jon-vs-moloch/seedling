{
  "productName": "Seedling",
  "version": "0.1.0",
  "identifier": "io.seedling.supervisor",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:7000",
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Seedling — ZenCode Supervisor",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:7000 http://127.0.0.1:8000 http://127.0.0.1:8001 http://127.0.0.1:9000 http://127.0.0.1:9001; img-src 'self' data: http://127.0.0.1:7000; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
